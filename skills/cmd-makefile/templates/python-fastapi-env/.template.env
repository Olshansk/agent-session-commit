# Copy this file to `.env` and fill in real values:
#   cp .template.env .env        (or: make env-template)
#
# `.env` is gitignored. `.template.env` IS committed and tracks schema over time.
# Every new env var in code => add a placeholder here the same PR.

# ---- Runtime ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Database ---------------------------------------------------------------
# SQLAlchemy needs the `postgresql+psycopg://` dialect marker for psycopg3.
# Port 5433 avoids clashing with a host Homebrew Postgres on 5432.
# If you use a managed Postgres URL (Render, Fly, Supabase) that comes back
# as `postgresql://...`, normalize it in a pydantic-settings validator —
# see reference.md "Render Postgres URL Normalization".
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/app_dev

# ---- CORS / auth / other service-specific knobs -----------------------------
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# GOOGLE_OAUTH_CLIENT_ID=
