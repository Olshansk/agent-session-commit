# Copy to `.env` (gitignored). `.template.env` is committed.
#
# Standalone postgres template — merge with your app's .template.env rather
# than shipping two files.

# Port 5433 dodges host Homebrew Postgres (5432). Change if you want.
# If your app uses SQLAlchemy+psycopg3, keep the `postgresql+psycopg://`
# prefix; pgcli is fine with the same URL via the `db-pgcli` recipe, which
# strips the `+psycopg` marker.
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/app_dev
